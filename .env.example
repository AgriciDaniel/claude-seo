# Umami self-hosted analytics credentials.
#
# Source of truth: 1Password TSE vault, item "Umami". Copy this file to
# `.env` (gitignored) and fill the values from the 1P item.
#
# Pattern: Foundry service-credentials standard
# (../the-foundry/standards/service-credentials.md).
# The same credential is consumed by `bearings`.

UMAMI_USERNAME=
UMAMI_PASSWORD=

# Optional. Override the default Umami host.
# UMAMI_BASE_URL=https://analytics.crafts.software

# Optional. Default --website-id for umami_stats.py. Run
# `python scripts/umami_stats.py check` to list available UUIDs.
# UMAMI_WEBSITE_ID=
